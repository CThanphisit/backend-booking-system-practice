// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  // output   = "../generated/prisma"
  output   = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum RoomStatus {
  AVAILABLE
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  WAITING_REVIEW  // user upload slip แล้ว รอ admin ตรวจ
  APPROVED        // admin อนุมัติแล้ว
  REJECTED        // admin ปฏิเสธ (สลิปผิด/ยอดไม่ตรง)
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  first_name  String
  last_name   String
  password    String
  phoneNumber String
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings    Booking[]

  @@map("users")
}

model Room {
  id            String     @id @default(cuid())
  roomNumber    String     @unique
  type          String     // "Standard" | "Deluxe" | "Suite" | "Family"
  floor         Int
  maxOccupancy  Int
  pricePerNight Decimal    @db.Decimal(10, 2)
  description   String?
  images        String[]
  status        RoomStatus @default(AVAILABLE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  bookings Booking[]

  @@map("rooms")
}

model Booking {
  id           String        @id @default(cuid())
  code         String        @unique // BK-xxxx
  userId       String
  roomId       String
  checkInDate  DateTime      @db.Date
  checkOutDate DateTime      @db.Date
  nights       Int
  guestCount   Int
  totalAmount  Decimal       @db.Decimal(10, 2)
  status       BookingStatus @default(PENDING)
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  payment      Payment?
  paymentDeadline DateTime?

  user User @relation(fields: [userId], references: [id])
  room Room @relation(fields: [roomId], references: [id])

  @@index([roomId, checkInDate, checkOutDate]) // สำหรับเช็คห้องว่าง
  @@map("bookings")
}

model Payment {
  id          String        @id @default(cuid())
  bookingId   String        @unique   // 1 booking = 1 payment
  amount      Decimal       @db.Decimal(10, 2)
  slipUrl     String        // URL รูปสลิปที่ user upload
  status      PaymentStatus @default(WAITING_REVIEW)
  note        String?       // admin ใส่หมายเหตุตอน reject
  reviewedBy  String?       // adminId ที่ตรวจ
  reviewedAt  DateTime?     // เวลาที่ตรวจ
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}